# ============================================
# Axie Lens - Variables de Entorno
# ============================================

# --- APIs Requeridas ---

# API Key de Sky Mavis (requerida para consultar datos de Axies)
# Obtén tu API key en: https://developers.skymavis.com/
SKYMAVIS_API_KEY=tu_api_key_de_skymavis

# --- APIs Opcionales ---

# Endpoint GraphQL de Sky Mavis (opcional, valor por defecto incluido)
# ENDPOINT_GRAPHQL=https://api-gateway.skymavis.com/graphql/axie-marketplace

# --- Telegram (Opcional) ---

# Token del bot de Telegram (opcional)
# Obtén tu token en: @BotFather
TELEGRAM_TOKEN=tu_token_de_telegram

# --- Configuración de Red (Opcional) ---

# Dirección del contrato Axie Ronin (opcional)
# AXIE_CONTRACT_ADDRESS=0x32950db2a7164ae833121501c797d79e7b79d74c

# Dirección base del marketplace de Axie Infinity (opcional)
# AXIE_MARKETPLACE_BASE=https://app.axieinfinity.com/

