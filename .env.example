# API Keys - Copy this to .env and fill in your values
MORALIS_API_KEY=your_moralis_api_key_here
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Axie Infinity Config
AXIE_CONTRACT=0x32950db2a7164ae833121501c797d79e7b79d74c
MARKETPLACE_GRAPHQL=https://graphql-gateway.axieinfinity.com/graphql
AXIE_MARKETPLACE_BASE=https://app.axieinfinity.com/marketplace/axies/

SKYMAVIS_API_KEY=your_skyavis_api_key_here
GRAPHQL_URL=https://api.thegraph.com/subgraphs/axieinfinity/axie-infinity
# =================================================================
# Estos valores deben ser actuales. Si expiran, el servidor dará 401/403.
# =================================================================
# Token de autorización (Bearer)
BEARER=your_bearer_here
# Cookie completa con cf_clearance
COOKIE_VALUE=your_cookie_value_here